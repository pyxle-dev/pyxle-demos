# Local development only (loaded by `pyxle dev`).
#
# Relax pyxle-auth's strict posture so the session cookie works over plain
# http://localhost and no production secret is required to boot. With no
# committed `strict` key, production leaves PYXLE_AUTH_STRICT unset — it
# defaults to true (Secure cookies + a real PYXLE_SECRET_KEY required), set
# on the host. Never put production secrets in this committed file.
PYXLE_AUTH_STRICT=false
