import logging

from pydantic import BaseModel, Field

# This page has no @server loader, so `pyxle build --static` pre-renders it to
# HTML at build time and `pyxle serve` warms the page cache with it — the fastest
# a page can be. (It is intentionally NOT runtime-cached: it hosts a per-user
# CSRF <Form>, and a shared cache can't carry a per-user token — see the / page
# for runtime ISR caching instead.)


class Subscribe(BaseModel):
    """The subscribe <Form> body. Pydantic enforces length; the email *shape* is
    checked in the action with a hand-rolled ValidationActionError so the user
    gets a clean message (not a raw regex). Both surface as a 422 the Form shows
    inline — the same per-field path as /report."""

    email: str = Field(min_length=3, max_length=160)


@action
async def subscribe(request, body: Subscribe):
    import re

    from db import add_subscriber

    email = body.email.strip().lower()
    # A custom check raising ValidationActionError (auto-injected in .pyxl) — the
    # message is exactly what the Form renders under the field.
    if not re.match(r"^[^@\s]+@[^@\s]+\.[^@\s]+$", email):
        # Empty top-level message: the per-field error carries the text, so the
        # Form's built-in form-level alert stays quiet and we render our own
        # on-theme message under the input.
        raise ValidationActionError(message="", fields={"email": ["Enter a valid email address."]})

    added = await add_subscriber(email)
    if added:
        # Confirmation goes out after the response — a background task.
        request.state.background.add_task(_send_confirmation, email)
    return {"email": email, "new": added}


def _send_confirmation(email: str) -> None:
    logging.getLogger("pulse").info("subscribe: confirmation queued for %s", email)


import React, { useState } from 'react';
import { Head, Link, Image, Form } from 'pyxle/client';
import { MonoLabel, FeatureTag, Card } from './components/ui.jsx';

export const slots = {};
export const createSlots = () => slots;

/* ── The feature map: every Pyxle capability and where Pulse shows it. ── */
const GROUPS = [
    {
        title: 'Server',
        accent: 'text-emerald-400',
        items: [
            ['File-based routing', 'Static, dynamic [id], nested', '/incidents/[id]'],
            ['@server loaders', 'Async data, colocated in the page', 'every page'],
            ['ISR caching', '{ data, revalidate } envelope', '/ status'],
            ['Static generation', 'No loader · pyxle build --static', 'this page'],
            ['@action + Pydantic', 'Typed body, 422 field errors', '/report'],
            ['Background tasks', 'Work after the response', '/report · subscribe'],
            ['error.pyxl + LoaderError', 'Status-aware boundary', 'unknown incident'],
        ],
    },
    {
        title: 'Realtime',
        accent: 'text-signal-400',
        items: [
            ['WebSockets', 'websocket(ws) in the page file', 'incident war room'],
            ['pyxle.realtime', 'channel() pub/sub broadcast', 'live timeline'],
            ['useWebSocket', 'status · send · lastMessage', 'live room'],
            ['Streaming SSR', 'Shell-first · loading.pyxl', '/incidents/*'],
        ],
    },
    {
        title: 'Client',
        accent: 'text-sky-400',
        items: [
            ['<Image>', 'CLS-safe, lazy, priority', 'this page'],
            ['<Script>', 'Self-hosted, afterInteractive', 'keyboard shortcuts'],
            ['<Form>', 'Progressive enhancement', 'subscribe below'],
            ['useAction', 'pending · error · fields', '/report'],
            ['<Head> / <Link> / navigate', 'Per-page meta · SPA nav', 'everywhere'],
